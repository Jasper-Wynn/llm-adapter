# =========================
# Server
# =========================
PORT=18002
SERVER_API_KEY=sk-local-adapter
REQUEST_TIMEOUT=120000
BODY_LIMIT=20mb

# =========================
# Provider
# =========================
PROVIDER_CLASS=app.provider.openai_compatible.OpenAICompatibleProvider
PROVIDER_TIMEOUT=300000

# =========================
# Logging
# =========================
LOG_LEVEL=debug
LOG_EXTERNAL_LEVEL=warning
LOG_CONSOLE=true
LOG_FILE=false
LOG_FILE_PATH=logs/server.log

# =========================
# Debug
# =========================
DEBUG_STREAM=true
DROP_THINKING_BLOCK=false
DEBUG_THROTTLE_TEXT_DELTA_MS=0

# =========================
# Uvicorn
# =========================
UVICORN_HOST=0.0.0.0
UVICORN_RELOAD=false
UVICORN_ACCESS_LOG=true
UVICORN_TIMEOUT_KEEP_ALIVE=2
UVICORN_TIMEOUT_GRACEFUL_SHUTDOWN=5
