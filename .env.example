# Local adapter runtime
HOST=127.0.0.1
PORT=18002
SERVER_API_KEY=sk-llm-adapter

# The only required startup selection: which upstream provider to load.
PROVIDER_CLASS=app.provider.glm.GLMProvider

# Request / debug
REQUEST_TIMEOUT=120000
BODY_LIMIT=20mb
LOG_LEVEL=info
DEBUG_STREAM=false
DROP_THINKING_BLOCK=false

# Provider HTTP defaults. Concrete providers inherit these and may override
# TIMEOUT / VERIFY_SSL / TRUST_ENV / HTTP2 directly in their provider class.
HTTP_TIMEOUT=300
HTTP_CONNECT_TIMEOUT=30
HTTP_VERIFY_SSL=true
HTTP_TRUST_ENV=false
HTTP2=true
HTTP_MAX_CONNECTIONS=200
HTTP_MAX_KEEPALIVE_CONNECTIONS=40
HTTP_KEEPALIVE_EXPIRY=30

